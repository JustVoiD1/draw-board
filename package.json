{
  "name": "drawboard",
  "private": true,
  "scripts": {
    "build": "dotenv -- turbo run build",
    "dev": "dotenv -- turbo run dev",
    "lint": "turbo run lint",
    "db:generate": "cd packages/db && npx prisma generate && cd ../../",
    "db:migrate": "cd packages/db && npx prisma migrate dev && cd ../../",

    "build:fe": "cd apps/drawboard-fe && bun run build",
    "start:fe": "cd apps/drawboard-fe && bun run start",
    "start:http": "cd apps/http-backend && bun run start",
    "start:ws": "cd apps/ws-backend && bun run start",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/pg": "^8.16.0",
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.7.4",
    "turbo": "^2.8.3",
    "typescript": "5.9.2"
  },
  "packageManager": "bun@1.3.9",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}